#include <iostream>
using namespace std;
int main() 
{
    int start, end;
    cout << "Enter start of range: "<<endl;
    cin >> start;
    cout << "Enter end of range: "<<endl;
    cin >> end;
    cout << "Prime Numbers: ";
    for (int num = start; num <= end; num++) 
    {
        if (num < 2)
            continue;
        bool isPrime = true;
        for (int i = 2; i < num; i++) 
        {
            if (num % i == 0) 
            {
                isPrime = false;
                break;
            }
        }
        if (isPrime)
            cout << num << " ";
    }
    return 0;
}
