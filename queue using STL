#include <iostream>
#include <queue>
using namespace std;
void showq(queue<int> gq)   //[]
{
    queue<int> g=gq;
    while(!g.empty())
    {
        cout<<'\t'<<g.front();
        g.pop();
    }
    cout<<'\n';
}

int main()
{
    queue<int> que;
    que.push(21);    //values pushed in stack should be of same data which is written during declaration of stack
    que.push(22); 
    que.push(24); 
   que.push(25); 
    cout<<"the queue que is: ";
    showq(que);
    cout<<"\n que.size() : "<<que.size();
     cout<<"\n que.front() : "<<que.front();
      cout<<"\n que.back() : "<<que.back();
      cout<<"\n que.pop() : ";
      que.pop();
      showq(que);
    return 0;
}
