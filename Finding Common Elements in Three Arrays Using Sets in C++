#include<iostream>
#include<set>
using namespace std;
int main()
{
    int arr1[]={1, 2, 3};
    int arr2[]={2, 3, 4};
    int arr3[]={3, 4, 5};
      int n1=sizeof(arr1)/sizeof(arr1[0]);
      int n2=sizeof(arr2)/sizeof(arr2[0]);
      int n3=sizeof(arr3)/sizeof(arr3[0]);
set<int> s1(arr1, arr1+n1);
set<int> s2(arr2, arr2+n2);
set<int> s3(arr3, arr3+n3);
cout<<"common elements is: ";
for(int x:s1)
{
    if(s2.count(x) && s3.count(x))
    {
        cout<<x<<" ";
    }
}
 return 0;
}
