#include<iostream>
#include<cstring>
using namespace std;
int main()
{
    char s[200];
    int count=0, i;
    cout<<"enter any string: "<<endl;
    cin.getline(s, 200);
    for(i=0; s[i]!='\0'; i++)
    {
        if(s[i]==' ')
        count++;
    }
    cout<<"number of words in the string is: "<<count+1<<endl;
    return 0;
}
