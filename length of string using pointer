#include<iostream>
using namespace std;
void mystrlen(char *s1);
int main()
{
    char str1[20];
    cout<<"enter any string: "<<endl;
    cin>>str1;
    mystrlen(str1);
    return 0;
}
void mystrlen(char *s1)
{
    int length=0;
    while(*s1!='\0')
    {
        length++;
        s1++;
    }
    cout<<"length of string is: "<<length<<endl;
}
