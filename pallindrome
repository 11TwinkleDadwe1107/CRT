#include<iostream>
using namespace std;
int main()
{
    int n, m;
    int r, rev=0;
    cout<<"enter the palindrome number"<<endl;
    cin>>n;
    while(n>0)
    {
        r=n%10;
        rev=rev*10+r;
        n=n/10;
    }
    if(rev==m)
    {
        cout<<"palindrome number"<<endl;
    }
    else
    {
        cout<<"not a palindrome number"<<endl;
    }
    return 0;
}
