    {
        for(j=0; j<size-i-1; j++)
        {
           if(arr[j]>arr[j+1])
           {
            int temp=arr[j];
            arr[j]=arr[j+1];
            arr[j+1]=temp;
           }
           for(int k=0; k<size; k++)
   {
    cout<<arr[k]<<"  ";
   }
   cout<<"\n";
}
cout<<"\n";
